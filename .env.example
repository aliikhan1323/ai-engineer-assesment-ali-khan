# Groq API key — sign up at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Superhero API token — sign in with GitHub at https://superheroapi.com
SUPERHERO_API_TOKEN=your_superhero_api_token_here

# Gemini API key — for embeddings (models/gemini-embedding-001)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile